<!DOCTYPE lacie-engine-room>
<room name="bathroom" folder="">
    <camera zoom="1.0" />
    <scripts>
        <script path="scripts/room_setup" />
        <script path="scripts/ch1/bedroom_event" />
    </scripts>

    <sprite name="bg_walls" x="0" y="0" z="1" sprite="sprite/ch1/shop/furniture_shelf">
        <script path="scripts/book" />
        <visibility visible="true" />
    </sprite>

    <sprite name="bed" x="120" y="300" z="19" sprite="sprite/ch1/home/bedroom_a/furniture_bed">
        <script path="scripts/bed" />
        <interaction interactable="false" dialog="data/dialogue/test_room" />
    </sprite>

    <sprite name="lamp" x="400" y="250" z="15" sprite="props/desk_lamp">
        <anim name="off" anim="lamp_off" fps="1" loop="false" />
        <anim name="on" anim="lamp_on_glow" fps="8" loop="true" />
        
        <interaction interactable="true" dialog="data/dialogue/bedroom/use_lamp" />
    </sprite>

    <player name="lacie" x="500" y="600" z="20" sprite="sprite/common/character/lacie/lacie">
        <visibility visible="true" />
    </player>

    <npc name="plushie_ghost" x="800" y="300" z="20" sprite="sprite/common/character/hiro/hiro">
        <anim name="run_down" anim="run_down" fps="10" loop="false" />
        <interaction interactable="true" dialog="data/dialogue/test_room" />
    </npc>

    <follower name="cursed_doll" z="21" sprite="sprite/common/character/hiro/hiro">
        <target name="lacie" distance="30" />
    </follower>

</room>